# === KIS API 실전투자 ===
KIS_APP_KEY=
KIS_APP_SECRET=

# === KIS API 모의투자 ===
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=

# === 계좌 정보 ===
KIS_ACCOUNT_NO=00000000-00        # 실전투자 계좌번호
KIS_MOCK_ACCOUNT_NO=00000000-00   # 모의투자 계좌번호
KIS_ACCOUNT_TYPE=01

# === 운용 설정 ===
MODE=mock                  # mock / real
TARGET_STOCKS=005930,000660
MAX_BUY_AMOUNT=500000
STOP_LOSS_PCT=-3.0
TAKE_PROFIT_PCT=5.0
MAX_DAILY_LOSS=100000          # 일일 최대 손실 한도 (원)
MAX_CONSECUTIVE_LOSSES=3       # 연속 손실 N회 시 자동 중단

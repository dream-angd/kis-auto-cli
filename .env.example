# === KIS API real trading ===
KIS_APP_KEY=
KIS_APP_SECRET=

# === KIS API mock trading ===
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=

# === Account ===
KIS_ACCOUNT_NO=00000000-00
KIS_MOCK_ACCOUNT_NO=00000000-00
KIS_ACCOUNT_TYPE=01

# === Common trading settings ===
MODE=mock
MAX_DAILY_LOSS=100000
# 계좌 전체 노출 한도 (원). 0이면 비활성. 예: 모의 5천만의 30% → 15000000
MAX_TOTAL_EXPOSURE=0
MAX_CONSECUTIVE_LOSSES=3
# 메인 루프에서 [scalp 상태] 블럭을 찍는 주기 (초). 최소 5초.
HEARTBEAT_INTERVAL_SEC=30
# 스캘프 동시 모니터링 종목 수 한도 (KIS API rate limit 20건/s 고려). 기본 10
MAX_SCALP_STOCKS=10

# === Swing strategy (5분 간격, 일봉 기반) ===
SWING_STOCKS=005930,000660
SWING_MAX_BUY_AMOUNT=500000
SWING_STOP_LOSS_PCT=-3.0
SWING_TAKE_PROFIT_PCT=5.0

# (legacy fallback — SWING_* 없을 때 사용. 신규 변수 사용 권장)
TARGET_STOCKS=005930,000660
MAX_BUY_AMOUNT=500000
STOP_LOSS_PCT=-3.0
TAKE_PROFIT_PCT=5.0

# === ATR 기반 포지션 사이징 ===
ATR_MULTIPLIER=2.0
ATR_RISK_PCT=0.01

# === 거래 비용 (수수료/거래세) ===
BUY_FEE_RATE=0.00015
SELL_FEE_RATE=0.00015
SELL_TAX_RATE=0.0020

# === 주문 체결 조회 ===
FILL_POLL_ATTEMPTS=3
FILL_POLL_INTERVAL_SEC=1.5

# === 종목명 매핑 (선택) ===
# KRX 코스피/코스닥 종목 마스터는 FinanceDataReader가 자동으로 가져옵니다 (.kis/stock_master.json에 24h 캐시).
# 별칭/약어를 쓰고 싶거나 KRX와 다른 이름을 강제하고 싶을 때만 추가.
# 형식: 코드:이름,코드:이름
# STOCK_NAMES=005930:삼전,000660:하닉

# === Scalp strategy (1.5초 간격, 모멘텀 기반) ===
# 단일: SCALP_STOCK=005930
# 다종목: SCALP_STOCKS=005930,035720,005380 (콤마 구분, 우선순위 높음)
SCALP_STOCKS=005930
SCALP_INTERVAL_SEC=1.5
SCALP_MAX_BUY_AMOUNT=2000000
SCALP_WINDOW_SIZE=6
SCALP_MIN_MOMENTUM_PCT=0.4
SCALP_TAKE_PROFIT_PCT=1.0
SCALP_STOP_LOSS_PCT=-0.5
SCALP_TRAILING_DROP_PCT=0.3
SCALP_MAX_HOLD_SEC=600
# 매수 시 호가 잔량 검증 (매수잔량/매도잔량 비율 최소). 1.0=매수≥매도, 0=비활성
SCALP_BID_ASK_RATIO_MIN=1.0
# 매도 판단 시 break-even 계산에 더할 슬리피지 버퍼 (소수). 기본 0.0005 = 0.05%
SCALP_SLIPPAGE_BUFFER_PCT=0.0005
# 장 마감 N분 전부터 신규 매수 차단 (기본 15분)
SCALP_NO_NEW_BUY_BEFORE_CLOSE_MIN=15
# 장 마감 N분 전부터 보유 종목 강제 청산 (기본 12분, KIS 정규 거래는 15:20 종료)
SCALP_FORCE_CLOSE_BEFORE_CLOSE_MIN=12

# Default behavior in code:
# - MODE=mock: scalp orders are enabled unless this is set false.
# - MODE=real: scalp orders are disabled unless this is set true.
SCALP_TRADE_ENABLED=

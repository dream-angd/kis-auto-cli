# === KIS API real trading ===
KIS_APP_KEY=
KIS_APP_SECRET=

# === KIS API mock trading ===
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=

# === Account ===
KIS_ACCOUNT_NO=00000000-00
KIS_MOCK_ACCOUNT_NO=00000000-00
KIS_ACCOUNT_TYPE=01

# === Common trading settings ===
MODE=mock
TARGET_STOCKS=005930,000660
MAX_BUY_AMOUNT=500000
STOP_LOSS_PCT=-3.0
TAKE_PROFIT_PCT=5.0
MAX_DAILY_LOSS=100000
MAX_CONSECUTIVE_LOSSES=3

# === Scalp strategy ===
SCALP_STOCK=005930
SCALP_INTERVAL_SEC=5
SCALP_MAX_BUY_AMOUNT=100000
SCALP_WINDOW_SIZE=6
SCALP_MIN_MOMENTUM_PCT=0.2
SCALP_TAKE_PROFIT_PCT=0.5
SCALP_STOP_LOSS_PCT=-0.3
SCALP_TRAILING_DROP_PCT=0.2
SCALP_MAX_HOLD_SEC=300

# Default behavior in code:
# - MODE=mock: scalp orders are enabled unless this is set false.
# - MODE=real: scalp orders are disabled unless this is set true.
SCALP_TRADE_ENABLED=
